# Antigravity Telegram CLI Bot
#
# Copy this file to .env, then protect it before entering secrets:
#   macOS/Linux: chmod 600 .env
#   Windows: use the icacls commands in README.md and inspect the resulting ACL.

# Required: create a bot with Telegram's BotFather.
BOT_TOKEN=

# Required: comma-separated numeric Telegram chat IDs.
# Private IDs are positive; group/supergroup IDs are negative.
ALLOWED_CHAT_IDS=858588087

# Optional global sender filter. Required by default when any group is allowed.
# In a private-only single-user deployment, the private chat ID is also the user ID.
# ALLOWED_USER_IDS=858588087

# Users allowed to run /auth. These must be positive IDs included in the effective
# allowed users. A sole private chat can infer its owner, but explicit is clearer.
# OWNER_USER_IDS is mandatory for group or multi-user deployments.
OWNER_USER_IDS=858588087

# Fail startup if a group is allowed without ALLOWED_USER_IDS.
REQUIRE_USER_ALLOWLIST_FOR_GROUPS=true

# OAuth codes stay in an allowed private owner chat by default.
AUTH_PRIVATE_ONLY=true

# Windows only: after restricting and reviewing the DACL for .env and the full
# DATA_DIR with icacls, set this true. Windows startup otherwise fails closed.
WINDOWS_ACL_VERIFIED=false

# Data/state locations. Relative paths resolve from the project working directory.
# When DATA_DIR is unset, Windows defaults to %LOCALAPPDATA%\agygram\data;
# macOS/Linux default to ./data.
# DATA_DIR=./data
# Every native service definition pins the resolved absolute DATA_DIR.
# Re-run `agygram service install` after changing this value.
# Every store below must be a strict descendant of DATA_DIR. Store files must
# be distinct; uploads, results, and agy run-log directories must not overlap.
# This keeps the instance lock, private ACL boundary, and cleanup ownership aligned.
# Leave these overrides unset normally. The ./data examples are valid only when
# DATA_DIR itself resolves to ./data (the macOS/Linux default); on Windows's
# LOCALAPPDATA default, use paths inside that resolved DATA_DIR instead.
# STATE_FILE=./data/sessions.json
# JOB_FILE=./data/jobs.json
# USAGE_FILE=./data/usage.json
# UPLOADS_DIR=./data/uploads
# RESULTS_DIR=./data/results
# AGY_RUN_LOG_DIR=./data/runtime/agy

# Bounded session state and inactive-session retention. This retention must be
# at least RESULT_RETENTION_HOURS so every retained result remains indexed.
MAX_STATE_SESSIONS=500
MAX_STATE_BYTES=16777216
STATE_RETENTION_HOURS=720

# Default directory in which agy runs. It is created automatically. Unlike the
# managed stores above, WORKSPACE_DIR may intentionally be outside DATA_DIR.
WORKSPACE_DIR=./data/workspace

# Optional extra roots accepted by /workspace. Symlinks are resolved before the
# containment check. Use ':' on macOS/Linux and ';' on Windows.
# ALLOWED_WORKSPACE_ROOTS=/home/me/projects:/srv/code
# ALLOWED_WORKSPACE_ROOTS=C:\Users\me\projects;D:\work

# Interactive runs can auto-detect known locations, but native service preflight
# requires resolution to an absolute executable. Set the absolute path explicitly
# for predictable service upgrades. Windows requires native agy.exe; shell shims fail.
# AGY_BIN=/home/me/.local/bin/agy
# AGY_BIN=C:\Tools\Antigravity\agy.exe

# agy receives a minimal child environment. List additional variable NAMES only
# when trusted tools require them; their values are copied from the bot process.
# This is a credential grant to the agent. Bot/Telegram/owner variables and
# loader/shell startup injection variables remain denied.
# AGY_ENV_ALLOWLIST=GOOGLE_CLOUD_PROJECT

# Process time and output limits.
AGY_TIMEOUT_MS=330000
AGY_AUTH_CHECK_TIMEOUT_MS=30000
AGY_AUTH_TIMEOUT_MS=900000
AGY_MAX_OUTPUT_BYTES=2097152

# Recover native conversation/project UUIDs from a private per-run agy log.
# The tested agy 1.1.1 log text is undocumented; local transcript is the fallback.
AGY_CAPTURE_RUN_METADATA=true

# False deletes a run log immediately after bounded metadata parsing. Logs left by
# crashes, and logs explicitly retained here, are still cleaned by TTL and quota.
AGY_KEEP_RUN_LOGS=false
AGY_RUN_LOG_RETENTION_HOURS=24
MAX_AGY_RUN_LOG_STORAGE_BYTES=52428800
MAX_AGY_RUN_LOG_FILE_BYTES=4194304

# Safe execution defaults.
DEFAULT_MODE=plan
DEFAULT_SANDBOX=true

# /apply uses accept-edits plus sandbox even if the stored session setting differs.
SANDBOX_PLAN_APPLY=true

# Master policy switch. While false, the execution layer forces every run into
# sandbox and /sandbox off is rejected.
ALLOW_UNSANDBOXED_RUNS=false

# Higher-risk opt-in. Requires ALLOW_UNSANDBOXED_RUNS=true and passes
# --dangerously-skip-permissions without sandbox.
ALLOW_UNSANDBOXED_AUTO_APPROVE=false

# Transcript fallback limits. agy accepts the prompt through --print argv, so the
# 24,000-character cap also leaves headroom under the Windows command-line limit.
# Process arguments are not secret from administrators/same-user local processes.
HISTORY_MAX_TURNS=20
HISTORY_MAX_CHARS=24000

# Durable Telegram update/job journal. JOB_HISTORY_LIMIT must be at least the
# MAX_PENDING_AGY_JOBS value configured below.
JOB_HISTORY_LIMIT=100
JOB_RESPONSE_MAX_CHARS=65536
JOB_JOURNAL_MAX_BYTES=16777216

# Update IDs survive job-history pruning in a bounded tombstone ledger so a
# delayed Telegram retry cannot execute twice. Retention must exceed
# MAX_UPDATE_AGE_SECONDS; the tombstone byte cap cannot exceed the journal cap.
# TELEGRAM_UPDATE_DEDUPE_LIMIT must cover the larger of history + pending jobs,
# or ceil(retention minutes / usage-window minutes) * global jobs + pending jobs.
# TELEGRAM_UPDATE_DEDUPE_MAX_BYTES must reserve at least 192 bytes per required
# dedupe entry plus 4096 bytes of ledger framing headroom.
TELEGRAM_UPDATE_DEDUPE_RETENTION_HOURS=48
TELEGRAM_UPDATE_DEDUPE_LIMIT=10000
TELEGRAM_UPDATE_DEDUPE_MAX_BYTES=4194304

# Durable abuse/cost guard. Job counts use a rolling window; runtime budgets
# reset at 00:00 UTC and charge a run to the UTC day on which it starts.
# Before spawning agy, the full AGY_TIMEOUT_MS is reserved so concurrent jobs
# cannot oversubscribe a budget. Completion replaces it with measured runtime;
# a crash leaves a conservative full-timeout charge on the next startup.
USAGE_WINDOW_MINUTES=60
MAX_AGY_JOBS_PER_USER_PER_WINDOW=20
MAX_AGY_JOBS_GLOBAL_PER_WINDOW=100
MAX_AGY_RUNTIME_MINUTES_PER_USER_PER_DAY=120
MAX_AGY_RUNTIME_MINUTES_GLOBAL_PER_DAY=480
USAGE_RETENTION_DAYS=8
USAGE_STORE_MAX_BYTES=4194304

# Concurrency. Sessions are still single-active-task and identical workspaces are
# serialized even when this value is raised.
MAX_CONCURRENT_AGY=1
MAX_UPDATE_AGE_SECONDS=300

# Bound admission and queue waiting before agy starts. Pending counts include
# admitted queued/running jobs; a session is always limited to one. Per-user
# limits span that user's allowed chats/topics on this bot instance.
AGY_QUEUE_TIMEOUT_MS=600000
MAX_PENDING_AGY_JOBS=16
MAX_PENDING_AGY_JOBS_PER_USER=3

# Upload limits. Telegram downloads also have a fixed 60-second timeout.
# MAX_UPLOAD_BYTES cannot exceed 20,000,000 in the current configuration parser.
MAX_UPLOAD_BYTES=20000000
UPLOAD_RETENTION_HOURS=24
MAX_UPLOAD_STORAGE_BYTES=209715200

# Full successful responses are kept outside sessions.json for /last recovery.
# RESULT_RETENTION_HOURS must not exceed STATE_RETENTION_HOURS.
# MAX_RESULT_STORAGE_BYTES must be at least AGY_MAX_OUTPUT_BYTES.
RESULT_RETENTION_HOURS=24
MAX_RESULT_STORAGE_BYTES=209715200

# Responses longer than this are sent as a UTF-8 document rather than message chunks.
MAX_INLINE_RESPONSE_CHARS=20000
MAX_REDELIVERY_BYTES=5242880

# POSIX native-service installation rejects group-writable executable/PATH
# components unless every relevant numeric gid is explicitly trusted here.
# TRUSTED_SERVICE_GROUP_GIDS=80

# Add SSH-style environment hints so agy emits a URL/code OAuth flow instead of
# attempting to open a browser on the bot host.
AUTH_FORCE_REMOTE=true
